# Copy this file to `.env` (same directory as docker-compose.yml) and fill
# in real values before running `docker compose up -d --build`.

# --- Database ---------------------------------------------------------------
DB_NAME=pentest_reporting
DB_USER=postgres
DB_PASSWORD=change-me-strong-password

# --- Django -------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1,your-domain.example
# Set to false ONLY for plain-HTTP local testing - cookies won't be sent
# by browsers over HTTP otherwise if true, and MUST be true in real prod.
DJANGO_COOKIE_SECURE=true

# Origin(s) the SPA is served from - must match exactly (scheme + host + port).
CORS_ALLOWED_ORIGINS=http://localhost

# --- Frontend -------------------------------------------------------------------
FRONTEND_PORT=80
