# Copy this file to `.env` (same directory as docker-compose.yml) and fill
# in real values before running `docker compose up -d --build`.

# --- Database ---------------------------------------------------------------
DB_NAME=pentest_reporting
DB_USER=postgres
DB_PASSWORD=DB_P455vv0rd

# --- Django -------------------------------------------------------------------
DJANGO_SECRET_KEY=kasldjvaldskjvkldjsvhlksjdvhjklsadvhdjksvh
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=backend,localhost,127.0.0.1,your-domain.example
# IMPORTANT: Set to false for plain-HTTP local dev (Docker Compose uses HTTP
# internally). Cookies won't be sent by browsers over HTTP if this is true.
# Switch back to true when deploying behind HTTPS in production.
DJANGO_COOKIE_SECURE=false

# Origin(s) the SPA is served from — must match exactly (scheme + host + port).
CORS_ALLOWED_ORIGINS=http://localhost

# --- Frontend -------------------------------------------------------------------
FRONTEND_PORT=80
